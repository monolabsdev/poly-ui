{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PolyUI",
  "version": "0.20.10",
  "identifier": "com.tslater.polyui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PolyUI",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 20
        },
        "dragDropEnabled": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; frame-src http: https:; child-src http: https:; img-src 'self' data: blob: https://www.google.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; media-src 'self' blob: data:; form-action 'self'; connect-src 'self' https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "target/onnxruntime/*onnxruntime*": ""
    },
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {},
      "rpm": {
        "depends": []
      }
    }
  }
}
